@page
@model LoginModel

@{
    ViewData["Title"] = "登入";
}

 <main id="forum" class="container-fluid">
            <!-- 登入畫面 -->
    <div class="login-content">
        <!-- 登入畫面左側 -->
        <div class="login-left col-12 col-lg-6">
            <div class="login-bgi">
                <div class="login-title">登入</div>
                <!-- 輸入帳號密碼之表單 -->
                <form class="login-form"  method="post">
                    <div class="login-account">
                        <p class="login-text">帳戶名稱</p>
                        <input id="account" type="email">
                    </div>
                    <div class="login-password">
                        <p class="login-text">密碼</p>
                        <input id="password" type="password">
                    </div>
                </form>
                <div class="login-btn-ctrl">
                   <button class="login-btn">登入</button>
                    <a href="forget.html">忘記密碼?</a>
                </div>
            </div>
            </div>
        <!-- 登入畫面右側 -->
        <div class="login-right col-12 col-lg-6">
            <p class="login-p">
                加入Steam   ，發掘千款可玩遊戲
            </p>
            <a href="#">深入了解</a>
            <div class="login-img">
                <img class="w-100" src="https://store.akamai.steamstatic.com/public/shared/images/login/join_pc.png?v=1">
            </div>
            <p class="login-p pt-3">免費加入又容易使用</p>
            <button class="login-btn2">加入Steam</button>
        </div>
    </div>
    </main>
