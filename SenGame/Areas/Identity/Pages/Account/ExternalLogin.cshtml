@page
@model ExternalLoginModel



<h2 id="external-login-title">用您的 @Model.ProviderDisplayName 帳號註冊</h2>


<div class="row mx-auto">
    <div class="col-md-4 mx-auto">
        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Input.Email" class="set-email">請輸入電子郵件</label>
                <input asp-for="Input.Email" class="form-control my-4" />
               @* <span asp-validation-for="Input.Email" class="text-danger"></span>*@
            </div>
            <button type="submit" class="ex-register">註冊</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@section Css{
     

    <style>
        main{
            height:100vh;
            text-align:center;
        }
        .ex-register{
             background-color: #f56c2d;
            width: 150px;
            height: 40px;
            border: 1px;
            border-radius: 3px;
            margin-top: 30px;
            color: #fff;
        }
        #external-login-title{
            font-size:4em;
            padding-top:3em;
        }
        .form-control{
            background-color: #e8f0fe;
        }
        .set-email{
            font-size:2em;
        }
        .form-group{
            padding-top:3em;
        }
    </style>
}