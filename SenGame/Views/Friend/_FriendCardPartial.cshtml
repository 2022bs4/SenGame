@foreach(var friend in Model){
        <div class="friend-li pl-2 py-3 w-100">
        <img class="friend-img user-select-none"  src="@friend.Photo">
        <div class="friend-content w-100">
            <span class="friend-name pl-4 mb-0 user-select-none">@friend.Name</span>
            <p class="friend-line pl-4 mb-0  user-select-none">上線</p>
        </div>
        </div>
}

