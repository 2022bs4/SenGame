 @section Css{
    <link rel="stylesheet" href="~/css/Friend/Member.css" asp-append-version="true"/>
 }

<!-- 下方區塊 (動態留言+個人狀態)  -->       
        <div class="mb-3 mt-3 ml-auto">
            <!-- 留言 + 新增留言 -->
            <div class="card-Member-Comment mb-3 mt-3 p-3 mr-3 ml-3">
                <div class="row g-0">
                    <!-- 右邊那塊 -->
                    <div class="col-md-4">
                        <div class="card-body card Member-card">
                            <!-- 顯示離線/上線狀態 -->
                            <!-- 整個編輯清單 -->
                            <div class="Edit-left-box">
                                <!-- 返回個人檔案 -->
                                <a href="/friend/User__information"
                                    class="btn btn-primary btn-block">返回個人檔案</a>
                                <!-- 編輯清單 -->
                                <div class="Edit-list mt-4 align-middle">
                                    <!-- 一般 (個人圖示+個人檔案背景+迷你個人檔案+主題 -->
                                    <a href="/friend/Edit1_User" class="list-group-item border-0"><span
                                            class="fa fa-inbox mr-2"></span>一般</a>
                                    <a href="/friend/Edit2_UserPhoto" class="list-group-item border-0"><span
                                            class="fa fa-paper-plane mr-2"></span>個人圖示</a>
                                    
                                    <a href="/friend/Edit3_UserTopic" class="list-group-item border-0"><span
                                            class="fa fa-ticket mr-2"></span>主題</a>
                                </div>
                                <!-- 分隔線 -->
                                <hr class="Edit-divider mt-1 m-b-10">
                                </hr>
                                <div class="list-group mail-list">
                                    <a href="/friend/Edit4_UserPrivacy" class="list-group-item border-0"><span
                                            class="fa fa-tags mr-2"></span><b>隱私設定</b></a>
                                    <!-- <a href="#" class="list-group-item border-0"><span class="fa fa-briefcase f-s-14 mr-2"></span>Work</a> 
                                        <a href="#" class="list-group-item border-0"><span class="fa fa-sellsy f-s-14 mr-2"></span>Private</a>
                                        <a href="#" class="list-group-item border-0"><span class="fa fa-ticket f-s-14 mr-2"></span>Support</a>  -->
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 編輯畫面 6-->
                    <div class="card-Edit6 col-md-8">
                        <!-- 編輯畫面群組 -->
                        <div class="Edit6-Group card">
                            <div class="card-body">
                                <!-- 關於個人圖示編輯的說明 -->
                                <div class="Edit6-text">
                                    <h5>我的基本資料</h5>
                                    <p>您的個人檔案名稱與圖示會顯示給任何造訪您的個人檔案的人，
                                        也會在多人遊戲中用來代表您。
                                    </p>
                                    <b class="Edit6-textTitle">
                                        <!-- 分隔線 -->
                                        <hr class="Edit-divider mt-1 m-b-10">
                                        </hr>
                                    </b>
                                </div>
                                <!-- 個人圖示編輯主要部分 -->
                                <div class="Edit6-main form-validation">
                                    <div class="row col-lg-12">
                                        <div class="card-body">
                                            <h4 class="card-title">我的個人檔案:</h4>
                                            <select class="form-control">
                                                <option value="public">公開</option>
                                                <option value="Friendsonly">僅限好友</option>
                                                <option value="personal">私人</option>
                                            </select>
                                            <p class="text-muted">您的社群個人檔案包括您的個人檔案摘要、好友名單、徽章、Steam 等級、展示欄、留言，以及群組成員資格。
                                            </p>
                                            <b class="Edit6-textTitle">
                                                <!-- 分隔線 -->
                                                <hr class="Edit-divider mt-1 m-b-10">
                                                </hr>
                                            </b>
                                            <p>亦包括以下您可以個別設定的項目</p>
                                            <!-- 遊戲資料 -->
                                            <div class="form-group row">
                                                <label class="col-lg-3 col-form-label" for="val-skill">遊戲資料
                                                </label>
                                                
                                                <div class="col-lg-9">
                                                    <p>
                                                        此部分包括您的 Steam 帳戶上的完整遊戲清單、您加入願望清單的遊戲、您的成就與遊玩時數。此設定亦會影響您在執行遊戲時，狀態是否會顯示「遊戲中」與遊戲名稱。
                                                    </p>
                                                    <select class="form-control">
                                                        <option value="public">公開</option>
                                                        <option value="Friendsonly">僅限好友</option>
                                                        <option value="personal">私人</option>
                                                            <div class="col-lg-8">
                                                                <label class="css-control css-control-primary css-checkbox" for="val-terms">
                                                                    <input type="checkbox" class="css-control-input" id="val-terms" name="val-terms" value="1"> <span class="css-control-indicator"></span> 即使使用者可以查看我的遊戲資料，仍將我的總遊玩數設為私人</label>
                                                            </div>
                                                    </select>
                                                </div>
                                                <!-- 好友清單 -->
                                            <div class="form-group row">
                                                <label class="col-lg-3 col-form-label" for="val-skill">好友名單
                                                </label>
                                                <div class="col-lg-9">
                                                    <p>
                                                        此設定會決定誰能在您的 Steam 社群檔案中查看您的好友名單。
                                                    </p>
                                                    <select class="form-control">
                                                        <option value="public">公開</option>
                                                        <option value="Friendsonly">僅限好友</option>
                                                        <option value="personal">私人</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <!-- 物品庫 -->
                                            <div class="form-group row">
                                                <label class="col-lg-3 col-form-label" for="val-skill">物品庫
                                                </label>
                                                <div class="col-lg-9">
                                                    <p>
                                                        您的物品庫包括您於使用 Steam 交易系統的遊戲中獲得的物品，以及任何您收集的 Steam 交換卡片、擁有的額外副本與 Steam 禮物。
                                                    </p>
                                                    <select class="form-control">
                                                        <option value="public">公開</option>
                                                        <option value="Friendsonly">僅限好友</option>
                                                        <option value="personal">私人</option>
                                                            <div class="col-lg-8">
                                                                <label class="css-control css-control-primary css-checkbox" for="val-terms">
                                                                    <input type="checkbox" class="css-control-input" id="val-terms" name="val-terms" value="1"> <span class="css-control-indicator"></span> 即使使用者可以查看我的物品庫，仍將我的Steam禮物設為私人</label>
                                                            </div>
                                                    </select>
                                                </div>
                                            </div>
                                            </div>
                                            
                                            
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

 @section Scripts{
     <script src="~/js/Friend/Chat.js"></script>
 }
