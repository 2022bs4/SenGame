@{
    ViewData["Title"] = "UploadFile";
}

<h1>File Upload單檔上傳</h1>

<form method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label for="uploadfile"></label>
        <input type="file" id="uploadfile" name="file" onchange="openFile(event)" accept="image/*" />
    </div>
    @*圖片預覽*@
    <div>
        <img id="output" height="200" style="display:none">
    </div>
    <div class="w-25 mt-3">
        <input type="submit" value="上傳" class="bg-dark text-white form-control"/>
    </div>
</form>

