                                                    <div class=" discount-price">NT$ 426</div>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </a>
                        </template>
                    </div>
                    <!-- 3的內容 -->
                    <div class="tab-hotBePost tab-pane fade" id="nav-contact" role="tabpanel"
                         aria-labelledby="nav-contact-tab">
                        <div class=" game-body d-flex justify-content-end"
