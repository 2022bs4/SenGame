                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </template>
                    </div>
                </div>

                <div class="tab-game-right">
                    <div>
                        <h3>遊戲名</h3>
                        <p class="text-muted">遊戲類型標籤</p>
                        <div style="font-size: 0.7em;">
                            <img class="pic-space" src="https://picsum.photos/300/200/?random=10">
