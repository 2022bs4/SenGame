 @section Css{
    <link rel="stylesheet" href="~/css/User/User.css" asp-append-version="true"/>
 }

<div class="mb-3 mt-3 ml-auto mt-3" id="card-Edit_User">
    <!-- 留言 + 新增留言 -->
    <div class="card-Member-Comment mb-3 mt-3 p-3 mr-3 ml-3">
        <div class="row g-0">
            @*右邊那塊*@
            <partial name="_UserEditPartial"/>
            <!-- 編輯畫面 5-->
            <div class="card-Edit6 col-md-8 card Member-card card-body">
                <!-- 編輯選擇主題群組 -->

                <!-- 關於主題顏色編輯的說明 -->
                <div class="Edit6-text">
                    <h5>主題</h5>
                    <p>選擇個人檔案頁面的背景色彩主題
                    </p>
                    <!-- 分隔線 -->
                    <hr class="Edit-divider mt-1 m-b-10">
                </div>
                <!-- 個人圖示編輯主要部分 -->
                <div class="Edit2-recoPhoto row mt-3">
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(90deg, rgb(243, 243, 249), rgb(243, 243, 249))')">
                            <img class="rounded-circle" src="https://img.onl/qEF6EH">
                            <h3 class="mt-3"> Original<br>setting</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(to top, #fbc2eb 0%, #a6c1ee 100%)')">
                            <img class="rounded-circle" src="https://img.onl/Yv1Zq">
                            <h3 class="mt-3"> Rainy<br>Ashville</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(120deg, #84fab0 0%, #8fd3f4 100%)')">
                            <img class="rounded-circle" src="https://img.onl/sLUpEL">
                            <h3 class="mt-3"> Tempt<br>Azure</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(120deg, #e0c3fc 0%, #8ec5fc 100%)')">
                            <img class="rounded-circle" src="https://img.onl/6KvN4j">
                            <h3 class="mt-3"> Deep<br>Blue</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color(' linear-gradient(to right, #fa709a 0%, #fee140 100%)')">
                            <img class="rounded-circle" src="https://img.onl/t4gZiw">
                            <h3 class="mt-3"> True<br>Sunset</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(to top, #a8edea 0%, #fed6e3 100%)')">
                            <img class="rounded-circle" src="https://img.onl/cLUn3">
                            <h3 class="mt-3"> Rare<br>Wind</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color('linear-gradient(to top, #fddb92 0%, #d1fdff 100%)')">
                            <img class="rounded-circle" src="https://img.onl/g4dZwJ">
                            <h3 class="mt-3"> Rare<br>Wind</h3>
                        </div>
                    </div>
                    <div class="col-lg-3 col-sm-6 ">
                        <div class="card Member-card p-3 btn photo1"
                            onclick="color(' linear-gradient(to right, #eea2a2 0%, #bbc1bf 19%, #57c6e1 42%, #b49fda 79%, #7ac5d8 100%)')">
                            <img class="rounded-circle" src="https://img.onl/cB0Qa5">
                            <h3 class="mt-3"> Rare<br>Wind</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- sweetalert -->
<script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

 @section Scripts{
     <script src="~/js/User/UserBtn03.js"></script>
 }