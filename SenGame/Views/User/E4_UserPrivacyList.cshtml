@model IEnumerable<SqlModels.Models.UserPrivacy>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PrivacyState)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UserPrivacyId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            @*</th></th>*@
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.PrivacyState)
            </td>
            <th>
                @Html.DisplayFor(modelItem => item.UserPrivacyId)
            </th>
            <td>
                @Html.DisplayFor(modelItem => item.User.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.UserPrivacyId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.UserPrivacyId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.UserPrivacyId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
