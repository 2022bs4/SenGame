

@section Css{
    <link rel="stylesheet" href="~/css/shop/Game.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />
}



<section class="Tag-Filter py-3">
            <nav aria-label="Page navigation example" class="col-12 d-flex justify-content-center">
                <ul class="pagination">
                    <li class="page-item popular"><a class="page-link" href="#">人氣最高</a></li>
                    <li class="page-item ComingSoon"><a class="page-link" href="#">即將發行</a></li>
                    <li class="page-item New-Releaese"><a class="page-link" href="#">最新發行日期</a></li>
                    <li class="page-item Earlier-Release"><a class="page-link" href="#">較早發行日期</a></li>
                    <li class="page-item Expensive-Product"><a class="page-link" href="#">價格由低至高</a></li>
                    <li class="page-item Cheap-Product"><a class="page-link" href="#">價格由高至低</a></li>
                    <li class="page-item Type-List">
                        <a class="page-link " href="#">類別</a>
                        <div class="Game-Type">
                            
                        </div>
                    </li>
                </ul>
            </nav>
</section>
<section class="Game-Swipper">
    <div class="title col-12">推薦遊戲</div>
    <div class="swiper mySwiper">
        <div class="swiper-wrapper">
        </div>
        <div class="swiper-pagination"></div>
    </div>
</section>
<section class="d-flex justify-content-center mt-4">
        <div id="carouselExampleCaptions" class="carousel slide col-8" data-ride="carousel">
            <ol class="carousel-indicators">
                <li data-target="#carouselExampleCaptions" data-slide-to="0" class="active"></li>
                <li data-target="#carouselExampleCaptions" data-slide-to="1"></li>
                <li data-target="#carouselExampleCaptions" data-slide-to="2"></li>
            </ol>
            <div class="carousel-inner">
            </div>
            <button class="carousel-control-prev" type="button" data-target="#carouselExampleCaptions"
                data-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="sr-only">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-target="#carouselExampleCaptions"
                data-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="sr-only">Next</span>
            </button>
        </div>
</section>
<section class="Game-List-Area d-flex justify-content-center flex-wrap mt-5">
    <nav aria-label="Page navigation example" class="col-12 d-flex justify-content-center">
        <ul class="pagination">
            <li class="page-item"><a class="page-link New-Product" href="#">新翉與話題商品</a></li>
            <li class="page-item"><a class="page-link Popular-Product" href="#">暢銷商品</a></li>
            <li class="page-item"><a class="page-link ComingSoon" href="#">即將發行</a></li>
            @*<li class="page-item"><a class="page-link " href="#">特惠</a></li>*@
        </ul>
    </nav>
    <div class="Game-List-Area col-9 d-flex flex-wrap ">
        <div class="Game-List col-12 col-md-8 pr-0"></div>
        <div class="Game-Data col-4 d-none d-md-flex pl-0"></div>
    </div>
</section>

<template id="Tag_Template">
    <ul class="d-flex flex-wrap py-2 px-0"
        <div class="col-4 Parent-Category">
            <a class="text-left pl-3 Parent-Category-Name"></a>
        </div>
        <div class="col-8 d-flex flex-wrap Subcategory">
        </div>
    </ul>
</template>
<template id="First_Swipper">
    <div class="swiper-slide">
        <img src="" alt=""/>
        <h2></h2>
        <p class="Game-Price"></p>
    </div>
</template>

<template id="Second_Swipper">
    <div class="carousel-item ">
    <img src=""class="d-block w-100" alt="...">
    <div class="carousel-caption d-none d-md-block">
        <h2 class="d-none">First slide label</h2>
        <p class="d-none"></p>
    </div>
</template>

<template id="Template_List">
    <div class="Template-List col-12 d-md-flex flex-wrap justify-content-md-between py-3">
        <div class="d-md-flex col-md-6  px-0">
            <img src="" alt=""class="w-100">
        </div>
        <div class="col-md-6 Game-Price p-0 ">
            <h2 class="Select-Game-Title pl-md-3 d-block"></h2>
            <div class="col-md-12 p-0 pl-md-3  d-flex justify-content-between">
                <p class=" d-inline-block font-weight-bold"></p>
            </div>
        </div>
        <input type="hidden" value=""/>
    </div>
</template>

<template id="Template_Data" class="">
    <div class="col-12 Template-Data pt-3 d-none">
        <h2></h2>
        <ul class="d-flex flex-wrap p-0"></ul>
    </div>
</template>

@section Scripts{
        <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
        <script src="~/js/shop/Game.js"></script>
}
